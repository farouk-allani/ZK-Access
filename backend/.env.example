# Server
PORT=3001

# Sumsub KYC (https://sumsub.com — sign up free, go to Dashboard > Developers)
SUMSUB_APP_TOKEN=your_sumsub_app_token
SUMSUB_SECRET_KEY=your_sumsub_secret_key
SUMSUB_BASE_URL=https://api.sumsub.com
SUMSUB_LEVEL_NAME=id-and-liveness
SUMSUB_WEBHOOK_SECRET=your_webhook_secret

# Aleo Network — issuer private key for auto-credential issuance
# This address must be registered as an authorized issuer via register_issuer()
ALEO_ISSUER_PRIVATE_KEY=your_aleo_issuer_private_key
ALEO_PROGRAM_ID=zkaccess_v3.aleo
ALEO_API_ENDPOINT=https://api.explorer.provable.com/v1
ALEO_NETWORK=testnet

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173
